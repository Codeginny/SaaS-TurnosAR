{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node App.jsx",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "db:migrate": "psql -h localhost -U postgres -d turnosar_db -f server/database/migrations/001_create_tables.sql",
    "db:reset": "psql -h localhost -U postgres -c \"DROP DATABASE IF EXISTS turnosar_db;\" && psql -h localhost -U postgres -c \"CREATE DATABASE turnosar_db;\" && npm run db:migrate",
    "db:seed": "psql -h localhost -U postgres -d turnosar_db -f server/database/seeds/seed_data.sql"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-moment": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.541.0",
    "moment": "^2.30.1",
    "mongoose": "^8.13.2",
    "pg": "^8.16.3",
    "react": "^18.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.0.0",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^7.5.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.1",
    "sweetalert2": "^11.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^18.0.10",
    "@types/react-dom": "^18.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^4.0.0"
  }
}
